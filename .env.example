# VetGPT — Full Environment Configuration
# Copy to .env and fill in your values

# ── App ────────────────────────────────────────
DEBUG=false
ENVIRONMENT=development

# ── Auth ───────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string-in-production!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ───────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/vetgpt.db

# ── LLM ────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL_ANTHROPIC=claude-sonnet-4-5
LLM_MODEL_OPENAI=gpt-4o
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
# ── RAG ────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.3
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=vet_manuals
EMBEDDING_PROVIDER=local

# ── Scraping ───────────────────────────────────
NCBI_API_KEY=

# ── Phase 3 Vision ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_AI_API_KEY=your-gemini-api-key-here           # Gemini fallback

# Google Document AI (cloud OCR)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json    # GCP service account key

# ── Stripe Billing ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_CLINIC_MONTHLY=price_xxxxxxxxxxxx
STRIPE_SUCCESS_URL=vetgpt://billing/success
STRIPE_CANCEL_URL=vetgpt://billing/cancel
STRIPE_PORTAL_RETURN_URL=vetgpt://profile

# ── PostgreSQL (production Docker) ────────────────────────────────────────────
POSTGRES_PASSWORD=changeme-use-a-strong-password

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com

# ── Bots ───────────────────────────────────────────────────────────────────────
# Shared bot user token — create a dedicated 'clinic' tier user for bots
BOT_API_KEY=eyJhbGciOiJIUzI1NiJ9...

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAF...      # from @BotFather
TELEGRAM_WEBHOOK_URL=https://api.vetgpt.app/telegram/webhook  # production
TELEGRAM_WEBHOOK_PORT=8443
TELEGRAM_WEBHOOK_SECRET=random-secret-string

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number
# Production: whatsapp:+254XXXXXXXXX        # your approved WA Business number


EXPO_PUBLIC_API_URL=http://192.168.1.101:8000   # your actual IP