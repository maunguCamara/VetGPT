# vetgpt-mobile/.npmrc
# pnpm configuration for Expo + React Native
#
# These settings are required for React Native / Expo to work correctly with pnpm.
# Without them, Metro bundler cannot resolve symlinked packages.

# Hoist all packages to node_modules root — Metro requires flat resolution
node-linker=hoisted

# Required for Expo prebuild and EAS Build
shamefully-hoist=true

# Ensure peer dependencies are installed automatically
auto-install-peers=true

# Strict peer dependency checking — warns but doesn't fail
strict-peer-dependencies=false

# Deduplicate packages with overlapping ranges
dedupe-peer-dependents=true
