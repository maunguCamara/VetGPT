{
  "expo": {
    "name": "VetGPT",
    "slug": "vetgpt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B6E4F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vetgpt.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "VetGPT needs access to photo library to analyze veterinary images",
        "NSCameraUsageDescription": "VetGPT needs camera access to capture veterinary images for analysis",
        "NSMicrophoneUsageDescription": "VetGPT needs microphone access for voice input features",
        "NSSpeechRecognitionUsageDescription": "VetGPT needs speech recognition access for voice input features"
      
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B6E4F"
      },
      "package": "com.vetgpt.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-document-picker",
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow VetGPT to access your camera to capture clinical images for analysis"
        }
      ],
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "VetGPT uses the microphone for voice queries.",
          "speechRecognitionPermission": "VetGPT uses speech recognition to transcribe your questions."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.0"
          },
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "scheme": "vetgpt",
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    }
  }
}